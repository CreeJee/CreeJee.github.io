{
  "name": "creejee.github.io",
  "description": "Resume site of CreeJee",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0",
      "onFail": "download"
    }
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "start": "vp dev --open",
    "build": "vp build",
    "preview": "vp preview --open",
    "typecheck": "tsc --incremental --noEmit",
    "fmt": "vp fmt .",
    "fmt.check": "vp fmt --check .",
    "lint": "vp lint \"src/**/*.ts*\"",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@mdx-js/react": "^3.1.0",
    "@mdx-js/rollup": "^3.1.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "20.19.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "0.7.1",
    "globals": "16.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "1.3.4",
    "typescript": "5.9.3",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "nuqs": "^2.9.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0"
  }
}
